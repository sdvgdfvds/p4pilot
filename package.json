{
  "name": "p4pilot-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "The Perforce-native layer for AI coding agents. Auto-checkout, changelist-aware edits, binary-asset guarding, and depot code review over MCP.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "pretest": "npm run build -w @p4pilot/core",
    "test": "vitest run",
    "pretest:coverage": "npm run build -w @p4pilot/core",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=lcov",
    "test:watch": "vitest",
    "typecheck": "tsc -b --pretty",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.3.0",
    "tsup": "^8.5.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.0"
  }
}
