{
  "mcpServers": {
    "p4pilot": {
      "command": "npx",
      "args": ["-y", "@p4pilot/mcp-server"],
      "env": {
        "P4PORT": "ssl:perforce.example.com:1666",
        "P4CLIENT": "your-workspace",
        "P4USER": "your-user"
      }
    },
    "p4pilot-mock": {
      "command": "npx",
      "args": ["-y", "@p4pilot/mcp-server", "--mock"]
    }
  }
}
